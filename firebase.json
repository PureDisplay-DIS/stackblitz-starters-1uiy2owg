{
  "hosting": {
    "site": "puredisplay-66e76",
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "trailingSlash": false,
    "cleanUrls": true,
    "rewrites": [
      {
        "source": "/parts/**",
        "destination": "/parts/index.html"
      },
      {
        "source": "/showroom/**",
        "destination": "/showroom/index.html"
      }
    ]
  }
}
